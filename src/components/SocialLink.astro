---
interface Props {
  href: string;
  label: string;
}
const { href, label } = Astro.props;
---
<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class="text-neutral-400 border border-neutral-700 rounded p-2 hover:border-neutral-500 hover:text-white transition-all duration-200 inline-flex items-center"
>
  <slot>{label}</slot>
</a>
