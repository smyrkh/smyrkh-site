---
interface Props {
  href: string;
  label: string;
}
const { href, label } = Astro.props;
---
<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="text-xs text-neutral-300 border border-neutral-700 rounded px-3 py-2 hover:border-neutral-500 hover:text-white transition-all duration-200"
>
  {label}
</a>
