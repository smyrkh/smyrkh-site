---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  tab: 'me' | 'experience' | 'this-site';
}

const { title, tab } = Astro.props;

const tabs = [
  { id: 'me',         label: 'Me',         href: '/about/me' },
  { id: 'experience', label: 'Experience',  href: '/about/experience' },
  { id: 'this-site',   label: 'This Site',   href: '/about/this-site' },
];
---

<Layout title={title}>
  <div class="min-h-screen max-w-4xl mx-auto px-6 py-16 sm:py-24">
    <nav class="mb-12">
      <a href="/" class="text-xs text-neutral-400 hover:text-neutral-200 transition-colors">← home</a>
    </nav>

    <div class="flex flex-col sm:flex-row gap-8 sm:gap-16">
      <aside class="flex-shrink-0">
        <nav class="flex flex-row sm:flex-col gap-6 sm:gap-1 border-b sm:border-b-0 border-neutral-800 pb-6 sm:pb-0">
          {tabs.map(t => (
            <a
              href={t.href}
              class={`text-sm py-1 transition-colors whitespace-nowrap ${
                tab === t.id
                  ? 'text-neutral-100'
                  : 'text-neutral-500 hover:text-neutral-300'
              }`}
            >
              {t.label}
            </a>
          ))}
        </nav>
      </aside>

      <main class="flex-1 min-w-0">
        <slot />
        <Footer />
      </main>
    </div>
  </div>
</Layout>
