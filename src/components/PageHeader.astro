---
interface Props {
  back: { href: string; label: string };
  title?: string;
}
const { back, title } = Astro.props;
---
<nav class="mb-12">
  <a href={back.href} class="text-xs text-neutral-400 hover:text-neutral-200 transition-colors">
    ← {back.label}
  </a>
</nav>
{title && (
  <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-12">{title}</p>
)}
