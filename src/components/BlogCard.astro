---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const displayDate = (post.data.updatedAt ?? post.data.createdAt).toISOString().slice(0, 10);
---

<a href={`/blog/${post.id}`} class="group block py-7 hover:opacity-80 transition-opacity">
  {post.data.image && (
    <img
      src={post.data.image}
      alt={post.data.title}
      class="w-full h-44 object-cover rounded mb-4 opacity-80 group-hover:opacity-100 transition-opacity"
    />
  )}

  <div class="flex items-center gap-3 mb-2">
    <time class="text-xs text-neutral-500 tabular-nums">{displayDate}</time>
    <span class="text-xs text-neutral-600">{post.data.category}</span>
  </div>

  <p class="text-sm font-semibold text-neutral-200 mb-2 group-hover:text-white transition-colors line-clamp-2">
    {post.data.title}
  </p>

  {post.data.description && (
    <p class="text-xs text-neutral-400 leading-relaxed mb-3 line-clamp-3">{post.data.description}</p>
  )}

  {post.data.tags.length > 0 && (
    <div class="flex gap-3 flex-wrap">
      {post.data.tags.map(tag => (
        <span class="text-xs text-neutral-600">#{tag}</span>
      ))}
    </div>
  )}
</a>
