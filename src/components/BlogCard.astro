---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const date = post.data.date.toISOString().slice(0, 10);
---

<a
  href={`/blog/${post.id}`}
  class="group block py-7 hover:opacity-80 transition-opacity"
>
  <div class="flex items-center gap-3 mb-2">
    <time class="text-xs text-neutral-500 tabular-nums">{date}</time>
    <span class="text-xs text-neutral-400 border border-neutral-700 rounded px-2 py-0.5">
      {post.data.category}
    </span>
  </div>
  <p class="text-sm font-semibold text-neutral-200 mb-2 group-hover:text-white transition-colors">
    {post.data.title}
  </p>
  {post.data.description && (
    <p class="text-xs text-neutral-300 leading-relaxed mb-3">{post.data.description}</p>
  )}
  {post.data.tags.length > 0 && (
    <div class="flex gap-3 flex-wrap">
      {post.data.tags.map(tag => (
        <span class="text-xs text-neutral-500">#{tag}</span>
      ))}
    </div>
  )}
</a>
