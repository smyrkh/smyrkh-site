---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "smyrkh's personal website" } = Astro.props;
---

<!doctype html>
<html lang="ja" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="bg-[#0a0a0a] text-neutral-100 min-h-screen font-mono antialiased">
    <slot />
  </body>
</html>
