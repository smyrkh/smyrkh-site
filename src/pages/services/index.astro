---
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import services from '../../data/services';
---

<Layout title="Services — smyrkh">
  <main class="min-h-screen max-w-2xl mx-auto px-6 py-16 sm:py-24">
    <PageHeader back={{ href: '/', label: 'home' }} title="Services" />

    {services.length > 0 ? (
      <ul class="grid gap-6 sm:grid-cols-2">
        {services.map(service => (
          <li><ServiceCard service={service} /></li>
        ))}
      </ul>
    ) : (
      <div class="flex flex-col gap-2">
        <p class="text-sm text-neutral-400">coming soon.</p>
        <p class="text-xs text-neutral-600">still building things.</p>
      </div>
    )}

    <Footer />
  </main>
</Layout>
