---
import Layout from '../../layouts/Layout.astro';
import SkillBadge from '../../components/SkillBadge.astro';
import SocialLink from '../../components/SocialLink.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';

const skillCategories = [
  { label: 'Languages',      skills: ['C', 'Java', 'Go', 'Python', 'Rust', 'Lua', 'Nix', 'HTML', 'CSS', 'SCSS', 'JavaScript', 'TypeScript', 'SQL', 'Bash', 'Zsh'] },
  { label: 'Frameworks',     skills: ['Astro'] },
  { label: 'OS',             skills: ['Linux', 'CentOS', 'RHEL', 'Arch Linux', 'NixOS', 'Ubuntu', 'Debian', 'macOS', 'Windows'] },
  { label: 'VCS',            skills: ['Git', 'Mercurial', 'SVN', 'GitHub', 'GitLab'] },
  { label: 'Infrastructure', skills: ['Docker', 'VMware', 'VirtualBox', 'UTM', 'Lima', 'Jenkins', 'AWS'] },
  { label: 'Editor / IDE',   skills: ['Neovim', 'Vim', 'VSCode', 'IntelliJ', 'Eclipse'] },
  { label: 'Services',       skills: ['Auth0', 'Gemini', 'Claude'] },
];
---

<Layout title="Profile — smyrkh">
  <main class="min-h-screen max-w-2xl mx-auto px-6 py-16 sm:py-24">
    <PageHeader back={{ href: '/', label: 'home' }} title="Profile" />

    <section class="mb-16">
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-4">About this site</p>
      <p class="text-sm text-neutral-200 leading-relaxed">
        smyrkh's personal website. A space for sharing background, thoughts, and projects I've built.
        Made with Astro and Tailwind CSS, deployed on AWS Amplify.
      </p>
    </section>

    <section class="mb-16 flex gap-8 items-start">
      <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-neutral-900 border border-neutral-800 flex-shrink-0 flex items-center justify-center">
        <span class="text-2xl font-bold text-neutral-500">s</span>
      </div>
      <div>
        <h1 class="text-xl font-bold text-neutral-100 mb-1">smyrkh</h1>
        <p class="text-xs text-neutral-400 mb-5">Software Engineer</p>
        <p class="text-sm text-neutral-200 leading-relaxed">
          Software engineer. Interested in systems programming, developer tooling, and Nix.
        </p>
      </div>
    </section>

    <section class="mb-16">
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-8">Skills</p>
      <div class="space-y-7">
        {skillCategories.map(({ label, skills }) => (
          <div>
            <p class="text-xs text-neutral-500 mb-3">{label}</p>
            <div class="flex flex-wrap gap-2">
              {skills.map(skill => <SkillBadge name={skill} />)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-6">Links</p>
      <div class="flex gap-3 flex-wrap">
        <SocialLink href="https://github.com/smyrkh" label="GitHub" />
        <SocialLink href="https://x.com/smyrkh" label="X" />
      </div>
    </section>

    <a
      href="/profile/history"
      class="group flex items-center justify-between border border-neutral-800 rounded-lg p-5 hover:border-neutral-600 hover:bg-neutral-900/50 transition-all duration-200"
    >
      <div>
        <p class="text-sm font-semibold text-neutral-200 group-hover:text-white transition-colors">History</p>
        <p class="text-xs text-neutral-300 mt-1">Education, career, and milestones.</p>
      </div>
      <span class="text-neutral-400 group-hover:text-neutral-200 group-hover:translate-x-0.5 transition-all duration-200 text-xs">→</span>
    </a>

    <Footer />
  </main>
</Layout>
