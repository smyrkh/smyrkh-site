---
import AboutLayout from '../../components/AboutLayout.astro';
---

<AboutLayout title="This Site — smyrkh" tab="this-site">
  <div class="flex flex-col gap-12">

    <section>
      <p class="text-sm text-neutral-300 leading-relaxed">
        smyrkh's personal website.
      </p>
    </section>

    <section>
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-5">Contents</p>
      <dl class="grid grid-cols-[6rem_1fr] gap-x-6 gap-y-3 text-sm">
        <dt class="text-neutral-600">About</dt>
        <dd class="text-neutral-300">自己紹介</dd>
        <dt class="text-neutral-600">Blog</dt>
        <dd class="text-neutral-300">失敗談・雑談</dd>
        <dt class="text-neutral-600">Projects</dt>
        <dd class="text-neutral-300">公開中のつくったもの</dd>
      </dl>
    </section>

    <section>
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-5">Stack</p>
      <dl class="grid grid-cols-[6rem_1fr] gap-x-6 gap-y-3 text-sm">
        <dt class="text-neutral-600">Framework</dt>
        <dd class="text-neutral-300">Astro</dd>
        <dt class="text-neutral-600">Styling</dt>
        <dd class="text-neutral-300">Tailwind CSS</dd>
        <dt class="text-neutral-600">Content</dt>
        <dd class="text-neutral-300">Markdown + Astro Content Collections</dd>
        <dt class="text-neutral-600">Deploy</dt>
        <dd class="text-neutral-300">AWS Amplify</dd>
      </dl>
    </section>

    <section>
      <p class="text-xs text-neutral-500 uppercase tracking-widest mb-5">Source</p>
      <a
        href="https://github.com/smyrkh/smyrkh-site"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-neutral-400 hover:text-neutral-100 transition-colors"
      >
        github.com/smyrkh/smyrkh-site →
      </a>
    </section>

  </div>
</AboutLayout>
