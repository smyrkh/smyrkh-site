---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const displayDate = (entry.data.updatedAt ?? entry.data.createdAt).toISOString().slice(0, 10);
const categorySegments = entry.data.category.split('/');
---

<Layout title={`${entry.data.title} — smyrkh`} description={entry.data.description}>
  <main class="min-h-screen max-w-2xl mx-auto px-6 py-16 sm:py-24">
    <PageHeader back={{ href: '/blog/all', label: 'blog' }} />

    <article>
      <header class="mb-12">
        <div class="flex items-center gap-1 text-xs text-neutral-600 mb-3">
          {categorySegments.map((seg, i) => (
            <>
              <span>{seg}</span>
              {i < categorySegments.length - 1 && <span>/</span>}
            </>
          ))}
        </div>

        <h1 class="text-2xl font-bold text-neutral-100 mb-3">{entry.data.title}</h1>

        {entry.data.description && (
          <p class="text-sm text-neutral-300 mb-4">{entry.data.description}</p>
        )}

        <div class="flex items-center gap-4">
          <time class="text-xs text-neutral-500 tabular-nums">{displayDate}</time>
          {entry.data.tags.length > 0 && (
            <div class="flex gap-3 flex-wrap">
              {entry.data.tags.map(tag => (
                <span class="text-xs text-neutral-500">#{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      {entry.data.image && (
        <img
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full rounded mb-10 opacity-90"
        />
      )}

      <div class="prose prose-invert prose-sm prose-neutral max-w-none
        prose-headings:font-mono prose-headings:font-semibold
        prose-code:font-mono prose-code:text-neutral-300
        prose-pre:bg-neutral-900 prose-pre:border prose-pre:border-neutral-800
        prose-a:text-neutral-300 prose-a:no-underline hover:prose-a:text-white
        prose-hr:border-neutral-800">
        <Content />
      </div>
    </article>

    <Footer />
  </main>
</Layout>
