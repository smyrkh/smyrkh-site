---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const counts = posts.reduce<Record<string, number>>((acc, { data }) => {
  acc[data.category] = (acc[data.category] ?? 0) + 1;
  return acc;
}, {});

const sorted = Object.entries(counts).sort(([, a], [, b]) => b - a);
const topCategories = sorted.slice(0, 3).map(([cat]) => cat);
const otherCategories = sorted.slice(3).map(([cat]) => cat);
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Layout title="Blog — smyrkh">
  <main class="min-h-screen max-w-2xl mx-auto px-6 py-16 sm:py-24">
    <PageHeader back={{ href: '/', label: 'home' }} title="Blog" />

    {posts.length === 0 ? (
      <div class="flex flex-col gap-2">
        <p class="text-sm text-neutral-400">coming soon.</p>
        <p class="text-xs text-neutral-600">still writing things.</p>
      </div>
    ) : (
      <>
        <div class="flex gap-2 flex-wrap mb-6">
          {['ALL', ...topCategories].map((cat, i) => (
            <button
              data-tab={cat}
              class={`text-xs px-3 py-1.5 border rounded transition-colors duration-150 ${i === 0 ? 'border-neutral-400 text-neutral-100' : 'border-neutral-700 text-neutral-400 hover:border-neutral-500 hover:text-neutral-200'}`}
            >
              {cat}
            </button>
          ))}
          {otherCategories.length > 0 && (
            <div class="relative">
              <button
                id="other-btn"
                data-tab="__other__"
                class="text-xs px-3 py-1.5 border border-neutral-700 rounded text-neutral-400 hover:border-neutral-500 hover:text-neutral-200 transition-colors duration-150"
              >
                more ▾
              </button>
              <div
                id="other-dropdown"
                hidden
                class="absolute top-full left-0 mt-1 min-w-max bg-[#0a0a0a] border border-neutral-800 rounded z-10 py-1"
              >
                {otherCategories.map(cat => (
                  <button
                    data-other={cat}
                    class="block w-full text-left text-xs px-4 py-2 text-neutral-400 hover:text-neutral-100 hover:bg-neutral-900 transition-colors"
                  >
                    {cat}
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>

        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-10">
            {allTags.map(tag => (
              <button
                data-tag-filter={tag}
                class="text-xs px-2 py-1 border border-neutral-800 rounded text-neutral-500 hover:border-neutral-600 hover:text-neutral-300 transition-colors duration-150"
              >
                #{tag}
              </button>
            ))}
          </div>
        )}

        <ul class="divide-y divide-neutral-900">
          {posts.map(post => (
            <li data-category={post.data.category} data-tags={JSON.stringify(post.data.tags)}>
              <BlogCard post={post} />
            </li>
          ))}
        </ul>
      </>
    )}

    <Footer />
  </main>
</Layout>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tab]'));
  const otherBtn = document.getElementById('other-btn');
  const dropdown = document.getElementById('other-dropdown');
  const items = document.querySelectorAll<HTMLElement>('[data-category]');
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]');
  const topTabValues = tabs.filter(t => t.dataset.tab !== '__other__').map(t => t.dataset.tab!);

  let activeCategory = 'ALL';
  let activeTags = new Set<string>();

  function applyFilter() {
    items.forEach(el => {
      const tags: string[] = JSON.parse(el.dataset.tags || '[]');
      const catMatch = activeCategory === 'ALL' || el.dataset.category === activeCategory;
      const tagMatch = activeTags.size === 0 || [...activeTags].every(t => tags.includes(t));
      el.hidden = !(catMatch && tagMatch);
    });
  }

  function setCategory(category: string) {
    activeCategory = category;
    applyFilter();
    tabs.forEach(btn => {
      const isActive = btn.dataset.tab === category ||
        (btn.dataset.tab === '__other__' && !topTabValues.includes(category));
      btn.classList.toggle('border-neutral-400', isActive);
      btn.classList.toggle('text-neutral-100', isActive);
      btn.classList.toggle('border-neutral-700', !isActive);
      btn.classList.toggle('text-neutral-400', !isActive);
    });
  }

  tabs.forEach(btn => {
    if (btn.dataset.tab !== '__other__') {
      btn.addEventListener('click', () => {
        setCategory(btn.dataset.tab!);
        if (dropdown) dropdown.hidden = true;
      });
    }
  });

  otherBtn?.addEventListener('click', e => {
    e.stopPropagation();
    if (dropdown) dropdown.hidden = !dropdown.hidden;
  });

  document.querySelectorAll<HTMLButtonElement>('[data-other]').forEach(btn => {
    btn.addEventListener('click', () => {
      setCategory(btn.dataset.other!);
      if (dropdown) dropdown.hidden = true;
    });
  });

  document.addEventListener('click', () => {
    if (dropdown) dropdown.hidden = true;
  });

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tagFilter!;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.classList.remove('border-neutral-400', 'text-neutral-100');
        btn.classList.add('border-neutral-800', 'text-neutral-500');
      } else {
        activeTags.add(tag);
        btn.classList.remove('border-neutral-800', 'text-neutral-500');
        btn.classList.add('border-neutral-400', 'text-neutral-100');
      }
      applyFilter();
    });
  });
</script>
