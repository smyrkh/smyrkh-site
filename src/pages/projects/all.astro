---
import ProjectLayout from '../../components/ProjectLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import projects from '../../data/projects';
---

<ProjectLayout title="Projects — smyrkh" tab="all">
  {projects.length > 0 ? (
    <ul class="grid gap-6 sm:grid-cols-2">
      {projects.map(project => (
        <li><ProjectCard project={project} /></li>
      ))}
    </ul>
  ) : (
    <div class="flex flex-col gap-2">
      <p class="text-sm text-neutral-400">coming soon.</p>
      <p class="text-xs text-neutral-600">still building things.</p>
    </div>
  )}
</ProjectLayout>
